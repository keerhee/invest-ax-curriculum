    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// 실제로는 W2 지표이력 시트에서 ticker 최신행 조회\n// 데모용: 간단 점수\nconst ticker = $('Webhook (verdict 요청)').first().json.body.ticker;\nreturn [{json:{ticker, priceScore: 0.4, priceReason: 'MA20 위·RSI 58'}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
