    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Vision 응답 파싱\nconst vTxt = $('Claude Vision').first()?.json?.content?.[0]?.text || '{}';\nconst vM = vTxt.match(/\\{[\\s\\S]*\\}/);\nconst v = vM ? JSON.parse(vM[0]) : {chart_score:0};\n\nconst p = $('Lookup Price (W2)').first().json;\nconst n = $('Lookup News (W3)').first().json;\n\nreturn [{json:{\n  ticker: p.ticker,\n  priceScore: p.priceScore, priceReason: p.priceReason,\n  newsScore: n.newsScore, newsReason: n.newsReason,\n  chartScore: v.chart_score, chartReason: (v.key_signals||[]).join(', '),\n}}];"
      },
