        "jsonBody": "{\"model\": \"claude-sonnet-4-5-20250929\", \"max_tokens\": 1024, \"messages\": [{\"role\": \"user\", \"content\": \"첨부된 일봉 차트(RSI·MACD·볼린저 포함)를 분석하라. JSON만 응답:\\n{\\n  \\\"trend\\\": \\\"uptrend|downtrend|sideways\\\",\\n  \\\"pattern\\\": \\\"head_shoulders|double_top|double_bottom|breakout|consolidation|none\\\",\\n  \\\"support\\\": 가격, \\\"resistance\\\": 가격,\\n  \\\"chart_score\\\": -1.0~1.0,\\n  \\\"key_signals\\\": [\\\"...\\\"]\\n}\"}]}",
