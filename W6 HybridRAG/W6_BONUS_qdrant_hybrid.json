    {
      "parameters": {
        "method": "POST",
        "url": "http://localhost:8000/embed_sparse",
        "options": {},
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"text\": \"={{$json.body.question}}\", \"model\": \"Qdrant/bm25\"}",
