      "id": "e8aec00b-5e5b-4dc7-8790-2117cfbc6081",
      "name": "Sparse Embed (FastEmbed)"
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Dense + Sparse 를 합쳐 Qdrant /points/query 본문 생성\nconst dense = $('Dense Embed (OpenAI)').first().json.data[0].embedding;\nconst sparse = $('Sparse Embed (FastEmbed)').first().json;  // {indices, values}\nconst orig = $('Webhook /hybrid').first().json.body;\n\nconst tickerFilter = orig.ticker\n  ? { must: [{ key: 'ticker', match: { value: orig.ticker } }] }\n  : undefined;\n\nreturn [{json:{\n  prefetch: [\n    { query: dense,                                    using: 'dense',  limit: 20 },\n    { query: { indices: sparse.indices, values: sparse.values }, using: 'sparse', limit: 20 }\n  ],\n  query:  { fusion: orig.fusion || 'rrf' },\n  limit:  orig.top_k || 5,\n  with_payload: true,\n  filter: tickerFilter\n}}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        0
      ],
      "id": "5f8fcde8-4866-4bdd-8c9d-0eb8f3b77cf9",
      "name": "Build Hybrid Query"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://YOUR-CLUSTER.qdrant.tech/collections/invest_disclosures/points/query",
        "options": {},
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "api-key",
              "value": "PUT_YOUR_QDRANT_KEY"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        260,
        0
      ],
      "id": "9f08667a-2c15-4f77-b3ec-898dda6abb9e",
      "name": "Qdrant Hybrid Query"
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Qdrant 결과 → Claude 컨텍스트로\nconst points = $json.result.points || [];\nconst ctx = points.map((p, i) => {\n  const pl = p.payload || {};\n  return `[${i+1}] ${pl.ticker || ''} ${pl.doc_type || ''} ${pl.doc_year || ''} p.${pl.page || '?'} (${pl.section || ''}): ${pl.content || ''}`;\n}).join('\\n\\n');\nreturn [{json:{ context: ctx, count: points.length }}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        520,
        0
      ],
      "id": "8b57ec99-3fd8-498c-a21a-0887fff383a8",
      "name": "Format Context"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "options": {},
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"model\": \"claude-sonnet-4-5-20250929\", \"max_tokens\": 1024, \"messages\": [{\"role\": \"user\", \"content\": \"너는 IR 분석가다. 검색 결과만으로 답변하고, 모든 주장에 [숫자] 형식 출처 인용 필수.\\n\\n질문: {{$node['Webhook /hybrid'].json.body.question}}\\n\\n검색결과:\\n{{$json.context}}\\n\\n답변:\"}]}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "PUT_YOUR_ANTHROPIC_KEY"
            },
            {
              "name": "anthropic-version",
              "value": "2023-06-01"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
