    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// 3개 응답에서 score + reason 추출 → 1개 row로 정리\nconst parsed = items.map(it => {\n  const txt = it.json?.content?.[0]?.text || '{}';\n  const m = txt.match(/\\{[\\s\\S]*\\}/);\n  return m ? JSON.parse(m[0]) : {score:0, reason:'', confidence:0};\n});\nconst orig = $('Webhook /verdict').first().json.body;\nreturn [{json:{\n  ticker: orig.ticker,\n  p_score: parsed[0].score, p_reason: parsed[0].reason,\n  n_score: parsed[1].score, n_reason: parsed[1].reason,\n  c_score: parsed[2].score, c_reason: parsed[2].reason,\n}}];"
      },
