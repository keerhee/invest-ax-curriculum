        "language": "javaScript",
        "jsCode": "// 같은 입력을 8개 Agent로 fanout\nconst ticker = $('Pick 가장 오래된 ticker').first().json.ticker;\nconst ragResp = $json;\nconst ctx = ragResp.context || ragResp.answer || JSON.stringify(ragResp).slice(0, 5000);\nconst agents = ['재무 트렌드','세그먼트','경제적 해자','Risk Factors','CEO 말바뀜','약속 이행','Bear Case (반대의견)','소스 갭'];\nreturn agents.map(name => ({json:{ ticker, agent: name, context: ctx }}));"
      },
