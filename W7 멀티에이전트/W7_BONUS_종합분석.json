        350
      ],
      "id": "7ab188a7-ce46-47f1-88fd-72d89ea8ef8d",
      "name": "소스 갭"
    },
    {
      "parameters": {
        "mode": "combine",
        "combineBy": "combineAll",
        "options": {}
