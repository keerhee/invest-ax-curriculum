      "id": "c9f3fa5b-e8bd-4a34-bcda-15356ded5282",
      "name": "Merge 8 Agents"
    },
    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// 8 Agent 응답에서 JSON 추출 + 통합\nfunction extractJson(content) {\n  if (!content) return {};\n  const txt = content?.[0]?.text || '';\n  const m = txt.match(/\\{[\\s\\S]*\\}/);\n  if (!m) return { raw: txt.slice(0, 500) };\n  try { return JSON.parse(m[0]); } catch (e) { return { raw: txt.slice(0, 500) }; }\n}\nconst combined = { ticker: '', sections: {} };\nfor (const it of items) {\n  const j = it.json;\n  // 어떤 Agent의 응답인지 — 직전 노드 이름으로 추정 어렵기 때문에 input.agent 보존 필요\n  // 실전: Agent별로 별도 키 보존하도록 prompt에 agent 라벨 포함시키거나 fanout 결과를 보존\n  const parsed = extractJson(j.content);\n  // Agent name이 응답에 들어있지 않으면 순서 기준\n  combined.sections[`agent_${Object.keys(combined.sections).length+1}`] = parsed;\n}\ncombined.ticker = $('Pick 가장 오래된 ticker').first().json.ticker;\ncombined.company = $('Pick 가장 오래된 ticker').first().json.company;\ncombined.analyzed_at = new Date().toISOString().slice(0,10);\nreturn [{json: combined}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1180,
        100
      ],
      "id": "af955e55-c60c-4d03-b45d-6db2bc814d17",
      "name": "Aggregate Results"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
