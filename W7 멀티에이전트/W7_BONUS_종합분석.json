      "parameters": {
        "language": "javaScript",
        "jsCode": "// 분석큐에서 active=TRUE + last_analyzed가 가장 오래된 ticker 1개 선택 (라운드로빈)\nconst rows = items.map(it => it.json).filter(r => r.active === true || r.active === 'TRUE' || r.active === true);\nif (rows.length === 0) {\n  throw new Error('분석큐가 비어 있습니다. ticker 추가 필요.');\n}\nrows.sort((a, b) => {\n  const da = a.last_analyzed || '1900-01-01';\n  const db = b.last_analyzed || '1900-01-01';\n  return da.localeCompare(db);\n});\nconst pick = rows[0];\nreturn [{json:{\n  ticker: pick.ticker,\n  company: pick.company,\n  industry: pick.industry,\n  picked_at: new Date().toISOString(),\n}}];"
      },
